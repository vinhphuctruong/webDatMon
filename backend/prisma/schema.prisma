generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
  STORE_MANAGER
  DRIVER
}

enum PartnerApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  PICKED_UP
  DELIVERED
  CANCELLED
}

enum CancelRequestStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum DiscountType {
  PERCENT
  FIXED
}

enum VoucherScope {
  ORDER
  SHIPPING
}

enum VoucherClaimSource {
  MARKET
  ADMIN
  AUTO
}

enum PaymentMethod {
  SEPAY_QR
  COD
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELED
  REFUNDED
}

enum CodHoldStatus {
  NONE
  HELD
  RELEASED
  REFUNDED
}

enum WalletOwnerType {
  USER
  STORE
  PLATFORM
}

enum WalletType {
  MERCHANT
  DRIVER_CREDIT
  DRIVER_CASH
  PLATFORM_ESCROW
  PLATFORM_REVENUE
}

enum WalletTxnDirection {
  CREDIT
  DEBIT
}

enum WalletTxnStatus {
  PENDING
  COMPLETED
  FAILED
}

enum WalletTransactionType {
  TOPUP_SEPAY
  WITHDRAW_REQUEST
  WITHDRAW_COMPLETED
  COD_HOLD
  COD_HOLD_RELEASE
  COD_HOLD_REFUND
  ORDER_ESCROW_IN
  ORDER_MERCHANT_SETTLEMENT
  ORDER_DRIVER_SETTLEMENT
  ORDER_PLATFORM_REVENUE
  ORDER_REFUND_OUT
  DRIVER_APP_FEE
  MANUAL_ADJUSTMENT
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
}

enum SePayTopupStatus {
  PENDING
  CONFIRMED
  EXPIRED
  CANCELED
}

model User {
  id                String            @id @default(uuid())
  email             String
  name              String
  phone             String?
  avatarUrl         String?
  passwordHash      String
  role              UserRole          @default(CUSTOMER)
  zaloId            String?           @unique
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  addresses         Address[]
  cartItems         CartItem[]
  orders            Order[]
  deliveryOrders    Order[]           @relation("OrderDriver")
  refreshToken      RefreshToken[]
  managedStore      Store?            @relation("StoreManager")
  driverProfile     DriverProfile?
  reviewedDriverApplications DriverApplication[] @relation("ReviewedDriverApplications")
  approvedDriverApplications DriverApplication[] @relation("ApprovedDriverApplications")
  wallets           Wallet[]          @relation("UserWallets")
  requestedPayouts  WalletPayout[]    @relation("RequestedPayouts")
  sepayTopupRequest SePayTopupRequest[]
  storeApplications StoreApplication[] @relation("UserStoreApplications")
  reviewedStoreApplications StoreApplication[] @relation("ReviewedStoreApplications")
  voucherClaims      VoucherClaim[]

  resetPasswordOtp       String?
  resetPasswordOtpExpiry DateTime?

  reviews                  Review[]
  productReviews           ProductReview[]
  givenDriverReviews       DriverReview[]    @relation("CustomerDriverReviews")
  receivedDriverReviews    DriverReview[]    @relation("DriverReceivedReviews")

  @@unique([email, role])
}

model Address {
  id           String   @id @default(uuid())
  userId       String
  label        String
  receiverName String
  phone        String
  street       String
  ward         String
  district     String
  city         String
  latitude     Float?
  longitude    Float?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders       Order[]

  @@index([userId])
}

model Store {
  id            String    @id @default(uuid())
  name          String
  slug          String    @unique
  address       String
  latitude      Float?
  longitude     Float?
  rating        Float     @default(0)
  etaMinutesMin Int       @default(20)
  etaMinutesMax Int       @default(35)
  isOpen        Boolean   @default(true)
  autoAcceptOrders Boolean @default(false)
  managerId     String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  products      Product[]
  orders        Order[]
  manager       User?     @relation("StoreManager", fields: [managerId], references: [id], onDelete: SetNull)
  wallets       Wallet[]  @relation("StoreWallets")

  reviews       Review[]

  @@index([name])
}

model Category {
  id        String            @id @default(uuid())
  key       String            @unique
  name      String
  slug      String            @unique
  iconUrl   String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  products  ProductCategory[]
}

model Product {
  id            String            @id @default(uuid())
  externalId    Int?              @unique
  storeId       String
  name          String
  slug          String            @unique
  description   String?
  imageUrl      String?
  price         Int
  discountType  DiscountType?
  discountValue Int?
  deliveryFee   Int               @default(15000)
  rating        Float             @default(0)
  soldCount     Int               @default(0)
  isAvailable   Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  store         Store             @relation(fields: [storeId], references: [id], onDelete: Restrict)
  categories    ProductCategory[]
  optionGroups  OptionGroup[]
  cartItems     CartItem[]
  orderItems    OrderItem[]

  reviews       ProductReview[]

  @@index([storeId])
  @@index([name])
}

model ProductCategory {
  productId  String
  categoryId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
}

model OptionGroup {
  id         String   @id @default(uuid())
  productId  String
  key        String
  name       String
  minSelect  Int      @default(0)
  maxSelect  Int      @default(1)
  isRequired Boolean  @default(false)
  sortOrder  Int      @default(0)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  options    Option[]

  @@unique([productId, key])
  @@index([productId])
}

model Option {
  id         String      @id @default(uuid())
  groupId    String
  key        String
  name       String
  priceDelta Int         @default(0)
  isDefault  Boolean     @default(false)
  sortOrder  Int         @default(0)
  group      OptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, key])
  @@index([groupId])
}

model CartItem {
  id              String   @id @default(uuid())
  userId          String
  productId       String
  quantity        Int
  selectedOptions Json
  optionsHash     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, optionsHash])
  @@index([userId])
}

enum DispatchStatus {
  PENDING
  OFFERED
  ACCEPTED
  BROADCAST
  EXPIRED
}

model Order {
  id                  String              @id @default(uuid())
  userId              String
  storeId             String
  driverId            String?
  addressId           String?
  status              OrderStatus         @default(PENDING)
  paymentMethod       PaymentMethod       @default(SEPAY_QR)
  paymentStatus       PaymentStatus       @default(PENDING)
  subtotal            Int
  deliveryFee         Int
  platformFee         Int
  discount            Int                 @default(0)
  voucherCode         String?
  total               Int
  merchantCommission  Int                 @default(0)
  driverCommission    Int                 @default(0)
  merchantPayout      Int                 @default(0)
  driverPayout        Int                 @default(0)
  platformRevenue     Int                 @default(0)
  codHoldAmount       Int                 @default(0)
  codHoldStatus       CodHoldStatus       @default(NONE)
  note                String?
  deliveryAddress     Json
  
  // Cancellation Request
  cancelRequestStatus CancelRequestStatus @default(NONE)
  cancelReason        String?

  estimatedDeliveryAt   DateTime?
  completedAt           DateTime?
  customerConfirmedAt   DateTime?
  placedAt              DateTime            @default(now())
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  user                  User                @relation(fields: [userId], references: [id], onDelete: Restrict)
  driver                User?               @relation("OrderDriver", fields: [driverId], references: [id], onDelete: SetNull)
  store                 Store               @relation(fields: [storeId], references: [id], onDelete: Restrict)
  address               Address?            @relation(fields: [addressId], references: [id], onDelete: SetNull)
  items                 OrderItem[]
  payment               OrderPayment?
  walletTransactions    WalletTransaction[]
  dispatch              OrderDispatch?

  review              Review?
  driverReview        DriverReview?
  productReviews      ProductReview[]

  @@index([userId, createdAt])
  @@index([status])
  @@index([driverId])
  @@index([storeId, status])
  @@index([paymentMethod, paymentStatus])
  @@index([completedAt])
}

model OrderDispatch {
  id              String         @id @default(uuid())
  orderId         String         @unique
  status          DispatchStatus @default(PENDING)
  currentDriverId String?
  offerExpiresAt  DateTime?
  attemptCount    Int            @default(0)
  maxAttempts     Int            @default(5)
  broadcastAt     DateTime?
  acceptedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  attempts        DispatchAttempt[]

  @@index([status])
  @@index([currentDriverId])
  @@index([offerExpiresAt])
}

model DispatchAttempt {
  id           String   @id @default(uuid())
  dispatchId   String
  driverId     String
  score        Float
  distanceKm   Float?
  timeMinutes  Float?
  offered      Boolean  @default(false)
  accepted     Boolean?
  respondedAt  DateTime?
  expiredAt    DateTime?
  createdAt    DateTime @default(now())

  dispatch     OrderDispatch @relation(fields: [dispatchId], references: [id], onDelete: Cascade)

  @@index([dispatchId])
  @@index([driverId])
}

model OrderItem {
  id              String   @id @default(uuid())
  orderId         String
  productId       String
  productName     String
  unitPrice       Int
  quantity        Int
  selectedOptions Json
  lineTotal       Int
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DriverProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  vehicleType  String
  licensePlate String   @unique
  isOnline     Boolean  @default(false)
  acceptanceRate Float  @default(1.0)
  cancellationRate Float @default(0.0)
  tier         String   @default("BASIC")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DriverApplication {
  id                       String                   @id @default(uuid())
  fullName                 String
  dateOfBirth              DateTime
  email                    String
  phone                    String?
  passwordHash             String
  vehicleType              String
  licensePlate             String
  portraitImageData        String
  idCardImageData          String
  driverLicenseImageData   String
  portraitQualityScore     Float
  idCardQualityScore       Float
  driverLicenseQualityScore Float
  status                   PartnerApplicationStatus @default(PENDING)
  adminNote                String?
  reviewedAt               DateTime?
  reviewedById             String?
  approvedUserId           String?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  reviewedBy               User?                    @relation("ReviewedDriverApplications", fields: [reviewedById], references: [id], onDelete: SetNull)
  approvedUser             User?                    @relation("ApprovedDriverApplications", fields: [approvedUserId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([email])
  @@index([licensePlate])
}

model StoreApplication {
  id                       String                   @id @default(uuid())
  applicantId              String                   
  storeName                String
  storeAddress             String
  storeLatitude            Float?
  storeLongitude           Float?
  storePhone               String
  businessLicenseImageData String?                  
  frontStoreImageData      String?                  
  status                   PartnerApplicationStatus @default(PENDING)
  adminNote                String?
  reviewedAt               DateTime?
  reviewedById             String?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  
  applicant                User                     @relation("UserStoreApplications", fields: [applicantId], references: [id], onDelete: Cascade)
  reviewedBy               User?                    @relation("ReviewedStoreApplications", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([applicantId])
}

model Wallet {
  id               String             @id @default(uuid())
  ownerType        WalletOwnerType
  ownerUserId      String?
  ownerStoreId     String?
  type             WalletType
  scopeKey         String             @unique
  currency         String             @default("VND")
  availableBalance Int                @default(0)
  holdBalance      Int                @default(0)
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  ownerUser        User?              @relation("UserWallets", fields: [ownerUserId], references: [id], onDelete: Cascade)
  ownerStore       Store?             @relation("StoreWallets", fields: [ownerStoreId], references: [id], onDelete: Cascade)
  transactions     WalletTransaction[]
  payouts          WalletPayout[]
  topupRequests    SePayTopupRequest[]

  @@index([ownerUserId])
  @@index([ownerStoreId])
  @@index([type])
}

model WalletTransaction {
  id              String                @id @default(uuid())
  walletId        String
  orderId         String?
  paymentId       String?
  payoutId        String?
  topupId         String?
  type            WalletTransactionType
  direction       WalletTxnDirection
  status          WalletTxnStatus       @default(COMPLETED)
  amount          Int
  availableBefore Int
  availableAfter  Int
  holdBefore      Int
  holdAfter       Int
  referenceCode   String?
  note            String?
  metadata        Json?
  createdAt       DateTime              @default(now())
  wallet          Wallet                @relation(fields: [walletId], references: [id], onDelete: Cascade)
  order           Order?                @relation(fields: [orderId], references: [id], onDelete: SetNull)
  payment         OrderPayment?         @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  payout          WalletPayout?         @relation(fields: [payoutId], references: [id], onDelete: SetNull)
  topup           SePayTopupRequest?    @relation(fields: [topupId], references: [id], onDelete: SetNull)

  @@index([walletId, createdAt])
  @@index([orderId])
  @@index([paymentId])
  @@index([payoutId])
  @@index([referenceCode])
}

model OrderPayment {
  id                 String              @id @default(uuid())
  orderId            String              @unique
  method             PaymentMethod
  status             PaymentStatus       @default(PENDING)
  amount             Int
  sepayReferenceCode String?             @unique
  sepayQrContent     String?
  sepayTransactionId String?
  paidAt             DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  order              Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  walletTransactions WalletTransaction[]

  @@index([status, createdAt])
}

model WalletPayout {
  id                String              @id @default(uuid())
  walletId          String
  requestedByUserId String?
  amount            Int
  fee               Int                 @default(0)
  netAmount         Int
  bankCode          String
  bankAccountNumber String
  bankAccountName   String
  status            PayoutStatus        @default(PENDING)
  sepayReferenceCode String?            @unique
  note              String?
  processedAt       DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  wallet            Wallet              @relation(fields: [walletId], references: [id], onDelete: Cascade)
  requestedByUser   User?               @relation("RequestedPayouts", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  transactions      WalletTransaction[]

  @@index([walletId, status])
  @@index([requestedByUserId])
}

model SePayTopupRequest {
  id                String               @id @default(uuid())
  walletId          String
  userId            String
  amount            Int
  status            SePayTopupStatus     @default(PENDING)
  referenceCode     String               @unique
  qrContent         String
  sepayTransactionId String?
  confirmedAt       DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  wallet            Wallet               @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions      WalletTransaction[]

  @@index([userId, createdAt])
  @@index([walletId, status])
}

model Review {
  id        String   @id @default(uuid())
  orderId   String   @unique
  userId    String
  storeId   String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([userId])
}

model ProductReview {
  id        String   @id @default(uuid())
  orderId   String
  productId String
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orderId, productId])
  @@index([productId])
}

// ── Hero Banner System ──────────────────────────
model HeroBanner {
  id        String   @id @default(uuid())
  title     String?
  imageUrl  String   /// base64 hoặc URL
  link      String?  /// URL khi click vào banner
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Voucher System ──────────────────────────

model Voucher {
  id              String        @id @default(uuid())
  code            String        @unique
  description     String
  scope           VoucherScope  @default(ORDER)
  isClaimable     Boolean       @default(true)  /// có hiển thị để khách "săn" / lưu hay không
  maxClaimTotal   Int?          /// tổng lượt LƯU tối đa (null = vô hạn)
  claimedCount    Int           @default(0)     /// tổng lượt đã LƯU
  autoGrantOnRegister Boolean   @default(false) /// tự động lưu cho khách mới khi đăng ký
  discountType    DiscountType  @default(FIXED)
  discountValue   Int           /// Giá trị giảm (VNĐ nếu FIXED, % nếu PERCENT)
  maxDiscount     Int?          /// Giảm tối đa (chỉ dùng cho PERCENT)
  minOrderValue   Int           @default(0) /// Đơn tối thiểu để áp dụng
  maxUsageTotal   Int?          /// Tổng lượt dùng tối đa (null = không giới hạn)
  maxUsagePerUser Int           @default(1) /// Mỗi user dùng tối đa mấy lần
  usedCount       Int           @default(0) /// Tổng lượt đã dùng
  isActive        Boolean       @default(true)
  startsAt        DateTime      @default(now())
  expiresAt       DateTime
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  usages          VoucherUsage[]
  claims          VoucherClaim[]

  @@index([code])
  @@index([isActive, startsAt, expiresAt])
}

model VoucherClaim {
  id        String             @id @default(uuid())
  voucherId String
  userId    String
  source    VoucherClaimSource @default(MARKET)
  claimedAt DateTime           @default(now())

  voucher   Voucher            @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([voucherId, userId])
  @@index([userId, claimedAt])
  @@index([voucherId, claimedAt])
}

model VoucherUsage {
  id          String   @id @default(uuid())
  voucherId   String
  userId      String
  orderId     String
  discount    Int      /// Số tiền đã giảm thực tế
  usedAt      DateTime @default(now())

  voucher     Voucher  @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@index([voucherId])
  @@index([userId, voucherId])
}

// ── Driver Review System ────────────────────────
model DriverReview {
  id        String   @id @default(uuid())
  orderId   String   @unique
  userId    String
  driverId  String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user      User     @relation("CustomerDriverReviews", fields: [userId], references: [id], onDelete: Cascade)
  driver    User     @relation("DriverReceivedReviews", fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([userId])
}
